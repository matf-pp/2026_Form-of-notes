import { AppPalette } from "palette.slint";
import { TaskHeader, MyButton, MyText } from "commons.slint";
import { LineEdit, ScrollView } from "std-widgets.slint";

export struct SlintTask {
    id: int, //interni id
    title: string,
    status: int, //0 DNS, 1 In Progress, 2 Done
    priority: int,
    total-hours: int,
    total-mins: int,
    total-days: int,
    deadline: string,
}

export component TaskView inherits VerticalLayout {
    in-out property <[SlintTask]> tasks: [];
    in-out property <bool> is-deadline-valid;

    callback get-tasks(int) -> [SlintTask];
    callback modify-task(int,int, string, string); //id, priority, title, deadline
    callback update-time(int, int, int); //add_time id, hours, mins
    callback finish-task(int);
    callback delete-task(int);
    callback is-valid-date(string) -> bool;

    padding: 10px;
    spacing: 4px;

    HorizontalLayout {
        MyText{
            text: "My tasks";
            font-size: 25px;
            horizontal-alignment: start;
        }
    }

    form-area := Rectangle{
        visible: false;
        height: self.visible ? 160px : 0px;
        animate height { duration: 150ms; easing: ease-in-out; }
        clip: true;
        background: AppPalette.bg-color.darker(10%);
        border-radius: 8px;
        border-width: 1px;
        border-color: AppPalette.primary-color;

        // local state for the form fields
        in-out property <int> wanted-id: -1;
        in-out property <string> new-title: "";
        in-out property <int>    new-priority: 1;       // default Medium
        in-out property <string> new-deadline: "";

        VerticalLayout {
            padding: 12px;
            spacing: 10px;

            // Title field
            HorizontalLayout {
                spacing: 8px;
                MyText {
                    text: "Title:";
                    color: AppPalette.text-color;
                    width: 70px;
                    vertical-alignment: center;
                }
                LineEdit {
                    placeholder-text: "My Task...";
                    width: 300px;
                    text: form-area.new-title;
                    edited(val) => { form-area.new-title = val; }
                }
            }

            // Priority field 1–5 with –+ button
            HorizontalLayout {
                spacing: 8px;
                MyText {
                    text: "Priority:";
                    color: AppPalette.text-color;
                    width: 70px;
                    vertical-alignment: center;
                }
                MyButton {
                    Text{width: parent.width; height: parent.height;
                        horizontal-alignment: center; vertical-alignment: center; text: "-";}
                    width: 36px;
                    clicked => {
                        if form-area.new-priority > 1 {
                            form-area.new-priority -= 1;
                        }
                    }
                }
                Rectangle {
                    width: 80px;
                    height: 36px;
                    border-radius: 6px;
                    border-width: 1px;
                    border-color: self.background.darker(30%);
                    background: form-area.new-priority == 5 ? #ba0000 :
                                form-area.new-priority == 4 ? #d27700 :
                                form-area.new-priority == 3 ? #ead51d :
                                form-area.new-priority == 2 ? #7ee045 : #50ffd3;
                    MyText {
                        width: parent.width;
                        height: parent.height;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                        color: #383838;
                        text: form-area.new-priority == 5 ? "Very high" :
                              form-area.new-priority == 4 ? "High" :
                              form-area.new-priority == 3 ? "Medium" :
                              form-area.new-priority == 2 ? "Low" : "Very low";
                    }
                }
                MyButton {
                    Text{width: parent.width; height: parent.height;
                        horizontal-alignment: center; vertical-alignment: center; text: "+";}
                    width: 36px;
                    clicked => {
                        if form-area.new-priority < 5 {
                            form-area.new-priority += 1;
                        }
                    }
                }
            }

            // Deadline field
            HorizontalLayout {
                spacing: 8px;
                MyText {
                    text: "Deadline:";
                    color: AppPalette.text-color;
                    width: 70px;
                    vertical-alignment: center;
                }
                dl := LineEdit {
                    width: 300px;
                    placeholder-text: "YYYY.MM.DD";
                    text: form-area.new-deadline;
                    edited(val) => { 
                        form-area.new-deadline = val;
                        is-deadline-valid = (is-valid-date(dl.text)) || (dl.text.character-count == 0) || (dl.text.character-count == 10); 
                    }
                }
                MyText {
                    text: is-deadline-valid ? "Valid!" : "Invalid date.";
                    color: is-deadline-valid ? AppPalette.secondary-color : #bd2323;
                }
                HorizontalLayout {
                alignment: end;
                MyButton {
                    text: "Add";
                    button-color: form-area.new-title == "" ?
                        AppPalette.primary-color.darker(40%) :
                        AppPalette.primary-color;
                    clicked => {
                        if form-area.new-title != "" && is-deadline-valid{
                            modify-task(
                                form-area.wanted-id,
                                form-area.new-priority,
                                form-area.new-title,
                                form-area.new-deadline
                            );
                            tasks = get-tasks(0);
                            // reset form
                            form-area.new-title = "";
                            form-area.new-priority = 1;
                            form-area.new-deadline = "";
                            form-area.visible = false;
                        }
                    }
                }
            }
            }

            // Confirm button
            
        }
    }

    HorizontalLayout {
        HorizontalLayout {
            spacing: 10px;
            alignment: start;
            TaskHeader { text: "Name"; clicked => {tasks = root.get-tasks(1);}}
            TaskHeader { text: "Status";}
            TaskHeader { text: "Priority"; clicked => {tasks = root.get-tasks(2);}}
            TaskHeader { text: "Deadline"; clicked => {tasks = root.get-tasks(3);}}
            TaskHeader { text: "Time spent:";}
        }
        HorizontalLayout {
            alignment: end;
            MyButton {
                text: form-area.visible ? "Cancel" : "Add Task";
                clicked => { 
                    form-area.visible = !form-area.visible; 
                    form-area.wanted-id = 0;
                    form-area.new-priority = 1;
                    form-area.new-deadline = "";
                    form-area.new-title = "";
                }
            }
        }

    }

    ScrollView {
        vertical-stretch: 1;

        VerticalLayout {
            spacing: 5px;
            for item[i] in tasks : HorizontalLayout {
            height: 34px;
            spacing: 10px;
            alignment: start;
            in-out property <int> task-id: item.id;

            //------------------------------------Title----------------------------
            Rectangle{
                width: 120px;
                height: 30px;
                TouchArea {
                    width: parent.width;
                    height: parent.height;
                    MyText {
                        vertical-alignment: center;
                        horizontal-alignment: left;
                        width: parent.width;
                        height: parent.height;
                        text: item.title;
                    }
                    clicked => {
                        form-area.wanted-id = item.id;
                        form-area.new-deadline = item.deadline;
                        form-area.new-priority = item.priority;
                        form-area.new-title = item.title;
                        form-area.visible = true;
                    }
                }
            }
    //------------------------------------Status----------------------------
            Rectangle{
                background: AppPalette.bg-color;
                width: 120px;
                height: 30px;
                MyText{
                    horizontal-alignment: center;
                    vertical-alignment: center;
                    text: item.status == 0 ? "Not started" : item.status == 1 ? "In progress" : "Finished";
                    color: AppPalette.secondary-color;
                }
            }
    //------------------------------------Priority----------------------------
            Rectangle{
                width: 120px;
                height: 30px;
                MyText{
                    text : item.priority == 5 ? "Very high" :
                        item.priority == 4 ? "High" :
                        item.priority == 3 ? "Medium" :
                        item.priority == 2 ? "Low" :
                        "Very low";
                    color: #383838;
                }
                background : item.priority == 5 ? #ba0000 :
                    item.priority == 4 ? #d27700 :
                    item.priority == 3 ? #ead51d :
                    item.priority == 2 ? #7ee045 :
                    #50ffd3;
            }
    //------------------------------------Deadline----------------------------
            Rectangle{
                width: 120px;
                height: 30px;
                MyText{
                    text : item.deadline;
                    color: AppPalette.text-color;
                }
                background : AppPalette.bg-color;
            }
    //------------------------------------TimePassed----------------------------
            Rectangle {
                width: 120px;
                height: 30px;

                border-color: ar.pressed ? AppPalette.primary-color.darker(30%) : 
                    ar.has-hover ? AppPalette.primary-color.brighter(20%) : 
                    AppPalette.primary-color;
                txt := MyText{
                    in-out property <int> days-passed: item.total-days;
                    in-out property <int> hrs-passed: item.total-hours;
                    in-out property <int> mins-passed: item.total-mins;
                    text: tim.running ? (tim.hr < 10 ? "0" : "") + tim.hr + ":" + (tim.min < 10 ? "0" : "") + tim.min :
                        (days-passed < 10 ? "0" : "") + days-passed  + ":" + 
                        (hrs-passed < 10 ? "0" : "") + hrs-passed + ":" + 
                        (mins-passed < 10 ? "0" : "") + mins-passed;
                }
                tim := Timer {
                    running: false;
                    out property <int> hr: 0;
                    out property <int> min: 0;
                    interval: 60000ms;
                    triggered() => {
                        min += 1;
                        if(min >= 60){
                            min -= 60;
                            hr += 1;
                        }
                    }
                }
                ar := TouchArea {
                    width: parent.width;
                    height: parent.height;

                    clicked => {
                        if tim.running {
                            tim.stop();
                            update-time(task-id, tim.hr, tim.min);
                            
                            tim.hr = 0;
                            tim.min = 0;
                        } else {
                            tim.start();
                        }
                    }
                }
            }
            Rectangle{
                width: 80px;
                height: 30px;
                background: ar2.pressed ? AppPalette.primary-color.darker(30%) : 
                    ar2.has-hover ? AppPalette.primary-color.brighter(20%) : 
                    AppPalette.primary-color;
                MyText{text: "Finish!"; color: white;}
                ar2 := TouchArea {
                    clicked => {
                        finish-task(task-id);
                    }
                }
            }
            Rectangle{
                width: 80px;
                height: 30px;
                background: ar3.pressed ? #720e0e :
                    ar3.has-hover ? #d31c1c : #a33434;
                MyText{text: "Delete"; color: white;}
                ar3 := TouchArea {
                    clicked => {
                        delete-task(task-id);
                    }
                }
            }
        }
    }

    }
}